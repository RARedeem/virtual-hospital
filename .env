# 复制为 .env 并填入强密码（.env 不应提交至版本库）
PG_USER=vhadmin
PG_PASSWORD=change_me_strong_password_here
PG_DB=virtual_hospital

MINIO_USER=vhminio
MINIO_PASSWORD=change_me_strong_password_here

# Authentik 身份提供方
# AUTHENTIK_SECRET_KEY 生成：openssl rand -base64 60
AUTHENTIK_SECRET_KEY=change_me_run_openssl_rand_base64_60
AUTHENTIK_DB=authentik

# OIDC — Authentik provider 已配置
# OIDC_ISSUER 必须与 JWT 的 iss claim 一致（浏览器侧地址，Authentik 写入 token 的值）
# OIDC_JWKS_URL 用容器内网地址，orchestrator 容器通过 Docker DNS 直连 Authentik 拉公钥
# 两者刻意不同：issuer 校验 iss claim，jwks_url 决定从哪里拉取公钥，是独立的两件事
OIDC_ISSUER=http://localhost:9100/application/o/virtual-hospital/
OIDC_JWKS_URL=http://authentik-server:9000/application/o/virtual-hospital/jwks/
OIDC_AUDIENCE=FqESExIdzWZZgkwh55IHiABpaSmasxfjAq1ztBVB
DEV_BYPASS_AUTH=1
